{
  "name": "desk-mcp-spike",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-27",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      { "name": "MCP_OBJECT", "class_name": "DeskMcpAgent" },
      { "name": "STORE",     "class_name": "Store" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["DeskMcpAgent", "Store"] }
  ],
  "dev": { "port": 8917, "ip": "127.0.0.1" }
}
